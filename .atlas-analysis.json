  "keyFeatures": [
    "HIP C++ runtime API and kernel language for portable GPU programming",
    "Comprehensive math libraries (BLAS, FFT, RAND, SOLVER, SPARSE)",
    "ML/AI acceleration with MIOpen, MIGraphX, Composable Kernel",
    "Multi-GPU collective communication via RCCL",
    "GPU profiling and tracing tools (ROCProfiler SDK, ROCm Compute Profiler)",
    "System management and monitoring (AMD SMI, rocminfo)",
    "LLVM-based ROCm compiler toolchain with HIPCC",
    "Full PyTorch and TensorFlow integration",
    "Support for CDNA (Instinct) and RDNA (Radeon) GPU architectures",
    "OpenCL and OpenMP programming model support"
  ],
  "publicApiSurface": [
    "HIP C++ Runtime API",
    "hipBLAS / rocBLAS",
    "hipFFT / rocFFT",
    "hipRAND / rocRAND",
    "hipSOLVER / rocSOLVER",
    "hipSPARSE / rocSPARSE",
    "MIOpen (deep learning primitives)",
    "MIGraphX (graph inference engine)",
    "RCCL (collective communications)",
    "rocPRIM / hipCUB (parallel primitives)",
    "AMD SMI (system management interface)",
    "ROCprofiler-SDK",
    "ROCm CMake build tools",
    "HIPIFY (CUDA to HIP translation)"
  ]
